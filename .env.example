# Admin credentials
ADMIN_USER=admin
ADMIN_PASS_HASH=   # Generated by setup script, or: node -e "console.log(require('bcryptjs').hashSync('yourpassword', 10))"

# Server
PORT=3200
JWT_SECRET=   # Generated by setup script, or: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# GitHub sync (optional — leave empty to disable)
GITHUB_TOKEN=
GITHUB_REPO=
GITHUB_BRANCH=main
